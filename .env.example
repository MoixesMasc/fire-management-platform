# ── AWS Global ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ── AWS Cognito ────────────────────────────────────────────────────────────────
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your_cognito_app_client_id
COGNITO_CLIENT_SECRET=your_cognito_app_client_secret   # leave empty if no secret

# ── DynamoDB Tables ────────────────────────────────────────────────────────────
REPORTS_TABLE=fire_reports
VALIDATIONS_TABLE=fire_validations
USERS_TABLE=fire_users

# ── Local Development (LocalStack) ─────────────────────────────────────────────
DYNAMODB_ENDPOINT_URL=http://localhost:4566

# ── Fire Validation Service ────────────────────────────────────────────────────
# Minimum Rekognition confidence score (50–99.9)
MIN_REKOGNITION_CONFIDENCE=80.0

# ── Notifications Service ──────────────────────────────────────────────────────
SNS_FIRE_ALERTS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:fire-alerts
SES_SENDER_EMAIL=alerts@your-domain.com
SES_CONFIGURATION_SET=fire-platform-events   # optional
NOTIFICATION_RADIUS_KM=5.0

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
